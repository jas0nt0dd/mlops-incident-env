# Final HF Job — best GPU tier + oracle SFT from traces.
# Job bootstrap downloads Hub files to /tmp/hf_repo (writable); SFT path must match.
# Precedence: this file overrides .env for the same keys when using scripts/_submit_hf_job_once.py

HF_JOB_FLAVOR=a100-large

HF_SPACE_URL=https://jason9150-mlops-incident-env.hf.space
HF_REPO_ID=jason9150/mlops-incident-agent-grpo-hf

# Oracle distilled JSONL on the model repo (upload with: python scripts/upload_oracle_artifacts.py)
SFT_ORACLE_JSONL=/tmp/hf_repo/data/oracle_sft.jsonl
SFT_EPOCHS=1
SFT_LR=2e-4
SFT_GRAD_ACCUM=4

RUN_MODE=balanced
RUN_PROFILE=full
NUM_EPOCHS=1
LR=6e-7
NUM_GEN=4
MAX_NEW_TOK=1024
EVAL_GREEDY=1
SAVE_BEST_BY_EVAL=1
N_EVAL_EPS=5
MID_EVAL_N_EPS=3
REWARD_MAX_SHAPING=0.05
REWARD_SHAPING_MIN_ENV=0.02
TRAIN_COUNTS_JSON={"easy":18,"medium":18,"hard":10,"cascade":10}

# Unsloth in Docker: skip HF stats ping (avoids 120s timeout inside Jobs)
UNSLOTH_DISABLE_STATISTICS=1

OUTPUT_DIR=mlops-grpo-final-a100
